DATABASE_URL=postgresql://ai_commerce:ai_commerce_local@localhost:5432/ai_commerce
TEST_DATABASE_URL=postgresql://ai_commerce:ai_commerce_local@localhost:5432/ai_commerce_test
# Only needed where DATABASE_URL points at a connection pooler; migrations use this instead.
DIRECT_DATABASE_URL=
OPENAI_API_KEY=
DUMMYJSON_BASE_URL=https://dummyjson.com
DUMMYJSON_TIMEOUT_MS=5000
E2E_MODE=false
# Optional. When unset, the catalog cache is disabled and DummyJSON is called directly.
REDIS_URL=redis://localhost:6379
CATALOG_CACHE_LIST_TTL_SECONDS=300
CATALOG_CACHE_DETAIL_TTL_SECONDS=1800
