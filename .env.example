DATABASE_URL=postgresql://ai_commerce:ai_commerce_local@localhost:5432/ai_commerce
TEST_DATABASE_URL=postgresql://ai_commerce:ai_commerce_local@localhost:5432/ai_commerce_test
OPENAI_API_KEY=
# Model used for every OpenAI call. Defaults to gpt-5.4-mini when unset.
OPENAI_MODEL=gpt-5.4-mini
# Optional per-call-site overrides. Each defaults to OPENAI_MODEL when unset.
# OPENAI_PLANNER_MODEL=gpt-5.4-mini
# OPENAI_REPLY_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_MS=20000
OPENAI_MAX_RETRIES=1
OPENAI_MAX_OUTPUT_TOKENS=2000
DUMMYJSON_BASE_URL=https://dummyjson.com
DUMMYJSON_TIMEOUT_MS=5000
REDIS_URL=redis://localhost:6379
CATALOG_CACHE_LIST_TTL_SECONDS=300
CATALOG_CACHE_DETAIL_TTL_SECONDS=1800
REPLY_COMPLETION_CACHE_TTL_SECONDS=300
