generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id        String    @id @default(uuid()) @db.Uuid
  title     String    @db.VarChar(80)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  messages  Message[]

  @@index([updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id                     String               @id @default(uuid()) @db.Uuid
  conversationId         String               @map("conversation_id") @db.Uuid
  clientRequestId        String?              @map("client_request_id") @db.Uuid
  replyToMessageId       String?              @unique @map("reply_to_message_id") @db.Uuid
  sequence               Int
  role                   MessageRole
  content                String               @default("")
  status                 MessageStatus
  retrievalAnchorMessage String?              @map("retrieval_anchor_message")
  lastSearchTerms        String[]             @default([]) @map("last_search_terms")
  lastCategorySlug       String?              @map("last_category_slug")
  focusedProductId       Int?                 @map("focused_product_id")
  createdAt              DateTime             @default(now()) @map("created_at")
  conversation           Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyToMessage         Message?             @relation("MessageReply", fields: [replyToMessageId], references: [id], onDelete: Cascade)
  assistantReply         Message?             @relation("MessageReply")
  productCards           MessageProductCard[]

  @@unique([conversationId, clientRequestId])
  @@unique([conversationId, sequence])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model MessageProductCard {
  messageId        String   @map("message_id") @db.Uuid
  position         Int
  productId        Int      @map("product_id")
  title            String
  shortDescription String   @map("short_description")
  price            Decimal  @db.Decimal(12, 2)
  imageUrl         String   @map("image_url")
  category         String
  rating           Decimal? @db.Decimal(3, 2)
  message          Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([messageId, position])
  @@map("message_product_cards")
}

enum MessageRole {
  user
  assistant
}

enum MessageStatus {
  pending
  complete
  failed
}
